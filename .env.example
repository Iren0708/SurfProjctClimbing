# Скопируйте в .env: cp .env.example .env  (Windows: copy .env.example .env)

# PostgreSQL (docker compose)
POSTGRES_DB=vertical
POSTGRES_USER=vertical
POSTGRES_PASSWORD=vertical
POSTGRES_PORT=5432

# Spring Boot API
API_PORT=8080
JWT_SECRET=dev-only-change-me-in-production-min-32-chars

# JDBC (локальный bootRun без docker-образа api)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/vertical
SPRING_DATASOURCE_USERNAME=vertical
SPRING_DATASOURCE_PASSWORD=vertical
